{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": "extracted",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/courses/([^/]+)", "dest": "/course-player.html" }
  ]
}
